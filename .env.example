# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_32_chars_min

# Resend (Email)
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
CONTACT_TO_EMAIL=info@wide-eleven.com

# Admin Bootstrap (first admin account)
ADMIN_BOOTSTRAP_EMAIL=admin@wide-eleven.com
ADMIN_BOOTSTRAP_PASSWORD=change_this_password
